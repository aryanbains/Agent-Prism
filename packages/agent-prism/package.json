{
  "name": "agent-prism",
  "version": "0.1.0",
  "description": "Drop-in tracing for any agent pipeline. Local SQLite, zero config, real costs.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  },
  "bin": {
    "agent-prism": "./dist/cli/index.js",
    "agentprism": "./dist/cli/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/app.d.ts",
      "import": "./dist/server/app.js",
      "require": "./dist/server/app.cjs"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "import": "./dist/parsers/index.js",
      "require": "./dist/parsers/index.cjs"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:cli && npm run build:dashboard",
    "build:lib": "tsup src/index.ts src/server/app.ts src/parsers/index.ts --format esm,cjs --dts --sourcemap --splitting false --clean",
    "build:cli": "tsup src/cli/index.ts --out-dir dist/cli --format esm --sourcemap --splitting false --clean false",
    "build:dashboard": "npm run build -w @agent-prism/dashboard",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "benchmark": "tsx benchmarks/trace-overhead.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "seed": "tsx examples/seed-demo.ts",
    "live:openrouter": "tsx examples/openrouter-live.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "better-sqlite3": "^12.10.0",
    "commander": "^12.1.0",
    "hono": "^4.6.14",
    "open": "^10.1.0"
  },
  "optionalDependencies": {
    "pg": "^8.13.1"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.24.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}